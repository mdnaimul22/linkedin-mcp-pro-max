<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cover Letter — {{ candidate_name }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary:      #0a0f1e;
            --accent:       #1d4ed8;
            --accent-soft:  #dbeafe;
            --accent-mid:   #93c5fd;
            --text-main:    #1e293b;
            --text-muted:   #64748b;
            --text-light:   #94a3b8;
            --bg-soft:      #f1f5f9;
            --border:       #e2e8f0;
            --white:        #ffffff;
        }

        * { box-sizing: border-box; -webkit-print-color-adjust: exact; print-color-adjust: exact; }

        body {
            font-family: 'DM Sans', sans-serif;
            line-height: 1.6;
            color: var(--text-main);
            background: #f8fafc;
            margin: 0;
            padding: 0;
        }

        @page {
            margin: 0;
            size: A4;
        }

        @media print {
            body { background: var(--white); }
            .page { box-shadow: none !important; margin: 0 !important; }
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            margin: 20px auto;
            background: var(--white);
            box-shadow: 0 4px 40px rgba(0,0,0,0.08);
            position: relative;
            overflow: hidden;
        }

        /* ── Top accent bar ─────────────────────── */
        .top-bar {
            height: 5px;
            background: linear-gradient(90deg, var(--accent) 0%, #3b82f6 50%, #60a5fa 100%);
        }

        /* ── Header ─────────────────────────────── */
        .header {
            padding: 36px 52px 26px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 24px;
        }

        .header-left {}

        .candidate-name {
            font-family: 'Syne', sans-serif;
            font-size: 32px;
            font-weight: 800;
            color: var(--primary);
            margin: 0;
            letter-spacing: -1px;
            line-height: 1.1;
        }

        .candidate-title {
            font-size: 12px;
            font-weight: 500;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 6px;
        }

        /* Contact items right-aligned */
        .contact-block {
            display: flex;
            flex-direction: column;
            gap: 6px;
            align-items: flex-end;
            flex-shrink: 0;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 12px;
            color: var(--text-muted);
        }

        .contact-item a {
            color: var(--accent);
            text-decoration: none;
        }

        .contact-icon {
            width: 14px;
            height: 14px;
            color: var(--accent-mid);
            flex-shrink: 0;
        }

        /* ── Body ────────────────────────────────── */
        .body {
            padding: 36px 52px 80px;
        }

        /* Job reference tag */
        .job-ref {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent-soft);
            border: 1px solid rgba(29, 78, 216, 0.15);
            color: var(--accent);
            font-size: 12px;
            font-weight: 500;
            padding: 5px 14px;
            border-radius: 5px;
            margin-bottom: 28px;
        }

        .job-ref-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--accent-mid);
        }

        /* Date + Recipient */
        .meta {
            margin-bottom: 24px;
        }

        .date {
            font-size: 13px;
            color: var(--text-light);
            margin-bottom: 14px;
        }

        .recipient {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.6;
            white-space: pre-line;
        }

        /* Greeting */
        .greeting {
            font-size: 15px;
            font-weight: 500;
            color: var(--primary);
            margin-bottom: 20px;
        }

        /* Paragraphs */
        .letter-body p {
            font-size: 14.5px;
            line-height: 1.75;
            color: var(--text-main);
            margin: 0 0 16px;
            text-align: justify;
        }

        .letter-body p:first-child::first-letter {
            font-family: 'Syne', sans-serif;
            font-size: 2.4em;
            font-weight: 800;
            float: left;
            line-height: 0.8;
            margin: 6px 6px 0 0;
            color: var(--accent);
        }

        /* Signature */
        .signature-block {
            margin-top: 28px;
        }

        .closing-line {
            font-size: 14.5px;
            color: var(--text-main);
            margin-bottom: 32px;
        }

        .sig-name {
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 2px;
        }

        .sig-title {
            font-size: 12px;
            color: var(--text-muted);
        }

        /* Divider */
        .divider {
            height: 1px;
            background: var(--border);
            margin: 24px 0;
        }

        /* ── Footer ──────────────────────────────── */
        .footer {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 10px 52px;
            font-size: 10.5px;
            color: var(--text-light);
            display: flex;
            justify-content: space-between;
            border-top: 1px solid var(--border);
            background: var(--white);
        }
    </style>
</head>
<body>
<div class="page">
    <div class="top-bar"></div>

    <!-- ── HEADER ──────────────────────────────── -->
    <header class="header">
        <div class="header-left">
            <h1 class="candidate-name">{{ candidate_name }}</h1>
            {% if candidate_title %}
            <div class="candidate-title">{{ candidate_title }}</div>
            {% endif %}
        </div>

        <div class="contact-block">
            {% if candidate_email %}
            <div class="contact-item">
                <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <a href="mailto:{{ candidate_email }}">{{ candidate_email }}</a>
            </div>
            {% endif %}
            {% if candidate_phone %}
            <div class="contact-item">
                <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.35 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {{ candidate_phone }}
            </div>
            {% endif %}
            {% if candidate_location %}
            <div class="contact-item">
                <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                {{ candidate_location }}
            </div>
            {% endif %}
            {% if candidate_linkedin %}
            <div class="contact-item">
                <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                <a href="{{ candidate_linkedin }}">LinkedIn</a>
            </div>
            {% endif %}
        </div>
    </header>

    <!-- ── LETTER BODY ──────────────────────────── -->
    <div class="body">

        <!-- Job reference badge -->
        {% if job_title and company %}
        <div class="job-ref">
            <span class="job-ref-label">Re</span>
            {{ job_title }} &mdash; {{ company }}
        </div>
        {% endif %}

        <!-- Date + Recipient -->
        <div class="meta">
            <div class="date">{{ date }}</div>
            {% if recipient %}
            <div class="recipient">{{ recipient }}</div>
            {% endif %}
        </div>

        <div class="greeting">{{ greeting }}</div>

        <div class="letter-body">
            <p>{{ introduction }}</p>
            {% for paragraph in body_paragraphs %}
            <p>{{ paragraph }}</p>
            {% endfor %}
            <p>{{ closing }}</p>
        </div>

        <div class="divider"></div>

        <!-- Signature -->
        <div class="signature-block">
            <div class="sig-name">{{ candidate_name }}</div>
            {% if candidate_title %}
            <div class="sig-title">{{ candidate_title }}</div>
            {% endif %}
        </div>

    </div>

    <footer class="footer">
        <span>{{ candidate_name }}</span>
        {% if job_title and company %}<span>{{ job_title }} &mdash; {{ company }}</span>{% endif %}
    </footer>
</div>
</body>
</html>