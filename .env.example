# LinkedIn Credentials
LINKEDIN_USERNAME="your-email@example.com"
LINKEDIN_PASSWORD="your-password"

# AI Provider Settings
# Options: claude, openai, ensemble
AI_PROVIDER="claude"
# Required if AI_PROVIDER is "claude" or "ensemble"
ANTHROPIC_API_KEY="sk-ant-..."
# Required if AI_PROVIDER is "openai" or "ensemble"
OPENAI_API_KEY="sk-..."

# Advanced AI Settings (Optional)
# AI_BASE_URL="https://integrate.api.nvidia.com/v1"
# AI_MODEL="meta/llama-3.1-405b-instruct"

# Browser Settings
HEADLESS=true
# CDP_URL="http://localhost:9222" # Connect to existing system browser
# CHROME_PATH="/usr/bin/google-chrome"
# USER_AGENT="Mozilla/5.0... (Optional)"
# VIEWPORT_WIDTH=1280
# VIEWPORT_HEIGHT=720
# SLOW_MO=0
# TIMEOUT=30000

# Session Settings
# USER_DATA_DIR="~/.linkedin-mcp/profile"
# DATA_DIR="~/.linkedin-mcp/data"
# LINKEDIN_EXPERIMENTAL_PERSIST_DERIVED_SESSION=true

# Logging
LOG_LEVEL="INFO"
